PORT=5001
# MongoDB Atlas Connection String (REQUIRED for cloud storage)
# Format: mongodb+srv://<username>:<password>@cluster0.mongodb.net/vms?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://admin:password@cluster0.abcde.mongodb.net/vms?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_key_here
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.vercel.app
